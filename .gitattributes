# Normalize line endings for all text files
* text=auto

# Python
*.py text eol=lf

# Web files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.svg text eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf

# Binary files — no line ending conversion
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.ico binary
